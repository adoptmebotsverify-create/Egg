-- Hatch button
hatchButton.MouseButton1Click:Connect(function()
    if isSpawning then
        warn("Already hatching an egg. Please wait...")
        return
    end
    
    local selectedEgg = eggNames[currentEggIndex]
    local ageMap = {1, 2, 3, 4, 5, 6}
    local options = {
        mega_neon = flagState["M"],
        neon = flagState["N"],
        flyable = flagState["F"],
        rideable = flagState["R"],
        age = ageMap[currentAge],
        trick_level = 5,
        rp_name = GenerateUniquePetName(),
        friendship_level = flagState["M"] and math.random(1, 5) or 1
    }
    
    hatchButton.Text = "HATCHING..."
    hatchButton.BackgroundColor3 = Color3.fromRGB(200, 100, 30)
    
    local hatchedPet = HatchEgg(selectedEgg, options)
    
    if hatchedPet then
        hatchButton.Text = "HATCHED!"
        hatchButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        
        -- Play hatch effect
        if hatchedPet.unique and SpawnedPets[hatchedPet.unique] then
            local petModel = SpawnedPets[hatchedPet.unique].model
            if petModel then
                -- Create egg shell effect
                local eggShell = Instance.new("Part")
                eggShell.Size = Vector3.new(2, 3, 2)
                eggShell.BrickColor = BrickColor.new(EggTypes[selectedEgg].color)
                eggShell.Material = Enum.Material.SmoothPlastic
                eggShell.Position = petModel.Position - Vector3.new(0, 2, 0)
                eggShell.Parent = workspace
                eggShell.Anchored = true
                eggShell.CanCollide = false
                
                -- Break egg animation
                TweenService:Create(eggShell, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
                    Size = Vector3.new(0.1, 0.1, 0.1),
                    Transparency = 1
                }):Play()
                
                task.wait(0.3)
                eggShell:Destroy()
            end
        end
        
        task.wait(1)
        hatchButton.Text = "HATCH EGG"
        hatchButton.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
    else
        hatchButton.Text = "FAILED!"
        hatchButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        task.wait(1)
        hatchButton.Text = "HATCH EGG"
        hatchButton.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
    end
end)

