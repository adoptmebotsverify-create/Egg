-- Hatch function
local function HatchEgg(eggName, options)
    if isSpawning then
        warn("Already hatching an egg. Please wait...")
        return nil
    end
    
    isSpawning = true
    options = options or {}
    
    -- Get egg data
    local eggData = EggTypes[eggName]
    if not eggData then
        eggData = EggTypes["Cracked Egg"] -- Default
    end
    
    -- Determine which pet to spawn
    local possiblePets = eggData.pets or CommonPets
    local selectedPet = possiblePets[math.random(1, #possiblePets)]
    
    -- Check for rare high-tier chance
    if math.random() <= (eggData.rareChance or 0.03) and #HighTierPets > 0 then
        selectedPet = HighTierPets[math.random(1, #HighTierPets)]
    end
    
    -- Create pet options
    local petOptions = {
        mega_neon = options.mega_neon or false,
        neon = options.neon or (math.random() <= 0.1), -- 10% chance for neon
        flyable = options.flyable or (math.random() <= 0.3), -- 30% chance for flyable
        rideable = options.rideable or true, -- Most pets are rideable
        age = options.age or math.random(1, 6),
        trick_level = options.trick_level or math.random(1, 5),
        rp_name = options.rp_name or GenerateUniquePetName(),
        friendship_level = options.friendship_level or 1
    }
    
    -- If mega neon, ensure it's also neon and has higher friendship
    if petOptions.mega_neon then
        petOptions.neon = true
        petOptions.friendship_level = math.random(3, 5)
    end
    
    -- Spawn the pet
    local petId = FindPetId(selectedPet)
    if petId then
        local result = CreateInventoryItem(petId, "pets", petOptions)
        task.wait(0.1)
        isSpawning = false
        return result
    end
    
    isSpawning = false
    return nil
end

-- Global hatch function
_G.hatch_egg = function(eggName, options)
    return HatchEgg(eggName, options)
end

