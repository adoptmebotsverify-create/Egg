-- Update egg preview
local function UpdateEggPreview()
    local eggData = EggTypes[eggNames[currentEggIndex]]
    eggIcon.BackgroundColor3 = eggData.color
    eggNameLabel.Text = eggNames[currentEggIndex]
    eggRarityLabel.Text = string.format("Rare chance: %.1f%%", eggData.rareChance * 100)
    
    -- Clear preview
    for _, child in pairs(previewScroll:GetChildren()) do
        if child:IsA("TextLabel") then
            child:Destroy()
        end
    end
    
    -- Show first 10 possible pets
    local count = 0
    for _, petName in ipairs(eggData.pets or CommonPets) do
        if count >= 10 then break end
        local petLabel = Instance.new("TextLabel")
        petLabel.Size = UDim2.new(1, -6, 0, 16)
        petLabel.BackgroundColor3 = Color3.fromRGB(40, 44, 66)
        petLabel.Text = "• " .. petName
        petLabel.Font = Enum.Font.Gotham
        petLabel.TextSize = 7
        petLabel.TextColor3 = Color3.fromRGB(200, 200, 255)
        petLabel.TextXAlignment = Enum.TextXAlignment.Left
        petLabel.Parent = previewScroll
        Instance.new("UICorner", petLabel).CornerRadius = UDim.new(0, 4)
        count = count + 1
    end
    
    if #(eggData.pets or {}) > 10 then
        local moreLabel = Instance.new("TextLabel")
        moreLabel.Size = UDim2.new(1, -6, 0, 16)
        moreLabel.BackgroundTransparency = 1
        moreLabel.Text = "... and " .. (#eggData.pets - 10) .. " more"
        moreLabel.Font = Enum.Font.Gotham
        moreLabel.TextSize = 7
        moreLabel.TextColor3 = Color3.fromRGB(150, 150, 200)
        moreLabel.TextXAlignment = Enum.TextXAlignment.Left
        moreLabel.Parent = previewScroll
    end
    
    previewScroll.CanvasSize = UDim2.new(0, 0, 0, previewLayout.AbsoluteContentSize.Y + 10)
end

prevEggButton.MouseButton1Click:Connect(function()
    currentEggIndex = currentEggIndex - 1
    if currentEggIndex < 1 then currentEggIndex = #eggNames end
    UpdateEggPreview()
end)

nextEggButton.MouseButton1Click:Connect(function()
