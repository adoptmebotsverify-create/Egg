-- Function to get all egg items from pets category
local function GetEggsFromDatabase()
    local eggs = {}
    
    -- Check if InventoryDB exists and has pets category
    if InventoryDB and InventoryDB.pets then
        for id, data in pairs(InventoryDB.pets) do
            -- Filter for egg items (they have "egg" in the name or ID)
            if data.name and (
                data.name:lower():find("egg") or 
                id:lower():find("egg") or
                (data.egg and data.egg == true)
            ) then
                table.insert(eggs, {
                    name = data.name,
                    id = id,
                    category = "pets",
                    data = data,
                    is_egg = true
                })
            end
        end
    end
    
    -- Sort eggs alphabetically by name
    table.sort(eggs, function(a, b)
        return a.name < b.name
    end)
    
    return eggs
end

