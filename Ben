local function GenerateUniqueEggName()
    local prefixes = {"★", "☆", "♡", "☁️", "✨", "🥚", "🐣", "🪺", "🌟", "💫", "⭐"}
    local names = {"Golden", "Shiny", "Mystic", "Ancient", "Crystal", "Magic", "Enchanted", 
                   "Rare", "Legendary", "Mythical", "Divine", "Sacred", "Blessed", "Cursed",
                   "Frozen", "Burning", "Storm", "Earth", "Sky", "Ocean", "Forest"}
    
    local usePrefix = math.random(1, 3) == 1
    local name = names[math.random(1, #names)]
    
    if usePrefix then
        return prefixes[math.random(1, #prefixes)] .. " " .. name .. " Egg"
    else
        return name .. " Egg " .. prefixes[math.random(1, #prefixes)]
    end
end

