local NextItemOrder = 60000

local function CreateInventoryItem(itemId, category, properties)
    local uniqueId = GenerateUniqueID()
    local itemKindData = KindDB[itemId]

    if not itemKindData then
        warn("Item not found in KindDB: " .. itemId)
        return nil
    end

    properties = properties or {}
    
    -- Special handling for eggs (they're in pets category)
    if category == "pets" and properties.is_egg then
        -- Eggs don't need pet-specific properties
        properties.pet_trick_level = nil
        properties.mega_neon = nil
        properties.neon = nil
        properties.rideable = nil
        properties.flyable = nil
        properties.age = nil
        properties.friendship_level = nil
        properties.ailments_completed = nil
        
        -- Add egg-specific properties
        properties.egg_hatch_time = properties.egg_hatch_time or (os.time() + 300) -- 5 minutes
        properties.is_egg = true
    end

    -- Set newness order
    NextItemOrder = NextItemOrder - 1
    local newnessValue = NextItemOrder

    local itemData = {
        unique = uniqueId,
        category = category,
        id = itemId,
        kind = itemKindData.kind,
        newness_order = newnessValue,
        properties = properties,
        _source = "4fire"
    }

    local identity = get_thread_identity and get_thread_identity() or 8
    set_thread_identity(2)
    local inventory = ClientData.get("inventory")
    if inventory and inventory[category] then
        inventory[category][uniqueId] = itemData
        print("✅ Added item to inventory: " .. itemId .. " in category " .. category)
        
        -- Mark this egg as equippable
        if properties.is_egg then
            equippableEggs[uniqueId] = true
        end
    else
        warn("Failed to add to inventory: category " .. category .. " not found")
    end
    set_thread_identity(identity)

    -- Track spawned items
    SpawnedItems[uniqueId] = true

    task.defer(function()
        if UIManager and UIManager.apps and UIManager.apps.BackpackApp then
            UIManager.apps.BackpackApp:refresh_rendered_items()
        end
    end)

    return itemData
end

local function DeleteAllSpawnedEggs()
    local identity = get_thread_identity and get_thread_identity() or 8
    set_thread_identity(2)
    
    local inventory = ClientData.get("inventory")
    local removed = 0
    
    -- Remove from inventory
    if inventory then
        for category, items in pairs(inventory) do
            if type(items) == "table" then
                for uniqueId, item in pairs(items) do
                    if item and item._source == "4fire" then
                        inventory[category][uniqueId] = nil
                        removed = removed + 1
                        -- Remove from equippable tracking
                        equippableEggs[uniqueId] = nil
                    end
                end
            end
        end
    end
    
    set_thread_identity(identity)
    
    -- Clear tracking tables
    SpawnedEggs = {}
    SpawnedItems = {}
    EquippedEgg = nil
    
    task.defer(function()
        if UIManager and UIManager.apps and UIManager.apps.BackpackApp then
            UIManager.apps.BackpackApp:refresh_rendered_items()
        end
    end)
    
    return removed
end

local function FindEggId(eggName)
    for _, egg in ipairs(EggTypes) do
        if egg.name:lower() == eggName:lower() then
            return egg.id, egg.category
        end
    end
    return nil, nil
end

local function FindItemId(itemName)
    -- First check eggs
    local eggId, eggCategory = FindEggId(itemName)
    if eggId then return eggId, eggCategory end
    
    return nil, nil
end

-- Global functions for egg spawning
_G.spawn_egg = function(eggName, options)
    if isSpawning then 
        warn("Already spawning an egg. Please wait...")
        return nil 
    end
    
    isSpawning = true
    options = options or {}
    local eggId, category = FindEggId(eggName)
    local result = nil
    
    if eggId then
        result = CreateInventoryItem(eggId, category or "pets", {
            is_egg = true,
            egg_name = options.egg_name or GenerateUniqueEggName(),
            egg_hatch_time = options.hatch_time or (os.time() + 300),
            -- Ensure no pet properties are set
            pet_trick_level = nil,
            mega_neon = nil,
            neon = nil,
            rideable = nil,
            flyable = nil,
            age = nil,
            friendship_level = nil,
            ailments_completed = nil
        })
        
        if result then
            print("✅ Spawned egg: " .. eggName .. " (ID: " .. result.unique .. ")")
            print("✅ This egg can be equipped normally!")
        end
    else
        warn("❌ Egg not found: " .. eggName)
    end
    
    task.wait(0.1)
    isSpawning = false
    return result
end

_G.spawn_all_eggs = function(options)
    if isSpawningAllEggs then
        warn("Already spawning all eggs. Please wait...")
        return {}
    end
    
    isSpawningAllEggs = true
    options = options or {}
    local spawnedEggs = {}
    
    for _, egg in ipairs(EggTypes) do
        local eggData = _G.spawn_egg(egg.name, options)
        if eggData then
            table.insert(spawnedEggs, eggData)
        end
        task.wait(0.05)
    end
    
    isSpawningAllEggs = false
    return spawnedEggs
end

_G.spawn_item = function(itemName, options)
    if isSpawning then 
        warn("Already spawning an item. Please wait...")
        return nil 
    end
    
    isSpawning = true
    options = options or {}
    local itemId, category = FindItemId(itemName)
    local result = nil

    if not itemId then
        warn("Item not found: " .. itemName)
    else
        result = CreateInventoryItem(itemId, category, options)
    end
    
    task.wait(0.1)
    isSpawning = false
    return result
end

