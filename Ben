-- Additional egg types (first 6 from the list)
local moreEggs = {}
for i = 1, math.min(6, #EggTypes) do
    local egg = EggTypes[i]
    -- Skip if already in quick eggs
    local isInQuick = false
    for _, qEgg in ipairs(quickEggs) do
        if qEgg[1] == egg.name then
            isInQuick = true
            break
        end
    end
    if not isInQuick then
        table.insert(moreEggs, {egg.name, Color3.fromRGB(100, 150, 200)})
    end
end

-- If we don't have enough, add some defaults
if #moreEggs < 6 then
    local defaults = {
        {"Jungle Egg", Color3.fromRGB(34, 139, 34)},
        {"Safari Egg", Color3.fromRGB(210, 180, 140)},
        {"Farm Egg", Color3.fromRGB(255, 215, 0)},
        {"Aussie Egg", Color3.fromRGB(0, 100, 0)},
        {"Japan Egg", Color3.fromRGB(255, 105, 180)},
        {"Danger Egg", Color3.fromRGB(255, 69, 0)},
    }
    for i = #moreEggs + 1, 6 do
        table.insert(moreEggs, defaults[i])
    end
end

for i, eggData in ipairs(moreEggs) do
    if i <= 6 then
        local row = math.floor((i-1) / 3)
        local col = (i-1) % 3
        
        local quickButton = Instance.new("TextButton")
        quickButton.Size = UDim2.new(0.32, -2, 0.45, -2)
