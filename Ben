-- Egg name input validation
nameInput:GetPropertyChangedSignal("Text"):Connect(function()
    local text = nameInput.Text
    local newText = autoCapitalize(text)
    if newText ~= text then
        nameInput.Text = newText
        return
    end
    
    if text == "" then
        inputGlow.Color = glowColors.neutral
        return
    end
    
    local isValid = FindEggId(text) ~= nil
    inputGlow.Color = isValid and glowColors.valid or glowColors.invalid
end)

-- Spawn button with non-stacking protection
spawnButton.MouseButton1Click:Connect(function()
    if isSpawning then
        warn("Already spawning an egg. Please wait...")
        return
    end
    
    local eggName = nameInput.Text
    if eggName == "" then return end
    
    local eggId = FindEggId(eggName)
    if not eggId then 
        warn("❌ Egg not found: " .. eggName)
        return 
    end
    
    local item = _G.spawn_egg(eggName, {
        egg_name = GenerateUniqueEggName(),
        hatch_time = os.time() + 300,
    })
    
    if item then
        spawnButton.Text = "SPAWNED!"
        task.wait(0.5)
        spawnButton.Text = "SPAWN EGG"
    end
end)

